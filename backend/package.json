{
  "name": "@montessori/backend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20 <25"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "npx tsc",
    "start": "node dist/server.js",
    "smoke:production": "node scripts/smoke-production.mjs",
    "test": "tsx --test test/security.test.ts test/auth-contract.test.ts && tsc --noEmit",
    "test:integration": "tsx --test test/api.test.ts test/repository.test.ts",
    "migrate": "npm run migrate:up",
    "migrate:status": "tsx src/database/migrate.ts status",
    "migrate:dry-run": "tsx src/database/migrate.ts dry-run",
    "migrate:up": "tsx src/database/migrate.ts up",
    "user:provision-admin": "tsx src/users/provisionAdmin.ts",
    "user:reset-password": "tsx src/users/resetPassword.ts"
  },
  "dependencies": {
    "@types/pdfkit": "^0.17.6",
    "@types/qrcode": "^1.5.6",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jose": "^6.1.3",
    "multer": "^2.0.2",
    "mysql2": "^3.15.3",
    "pdfkit": "^0.19.1",
    "qrcode": "^1.5.4",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.10.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
PORT=4000
NODE_ENV=production
JWT_SECRET=replace-with-at-least-32-random-characters
DATA_ENCRYPTION_KEY=base64-encoded-32-byte-key
DB_HOST=your-hostinger-mysql-host
DB_PORT=3306
DB_USER=your-database-user
DB_PASSWORD=your-database-password
DB_NAME=your-existing-database-name
DB_CONNECTION_LIMIT=10
DB_SSL=true
UPLOAD_ROOT=/absolute/persistent/path/to/montessori-uploads
FRONTEND_ORIGIN=https://montessori-portal-frontend.vercel.app
ALLOW_PRODUCTION_MIGRATIONS=false
